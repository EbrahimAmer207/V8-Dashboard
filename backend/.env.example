# App
NODE_ENV=development
PORT=3001
APP_NAME=Admin Dashboard

# Database - SQLite (local development)
DATABASE_URL="file:../data/dev.db"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRATION=7d

# Development only: any valid email + password logs you in without AspNetUsers (never in production)
AUTH_DEV_BYPASS=false

# CORS
CORS_ORIGIN=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
PUBLIC_MEDIA_URL=http://e7nama3ak.runasp.net
MEDIA_BASE_URL=http://e7nama3ak.runasp.net

# Optional: send dashboard podcast uploads to the same .NET/mobile backend that the app uses.
# Requires a valid mobile/.NET JWT and a patient id accepted by /api/DoctorSessions/{patientId}.
DOTNET_API_URL=http://e7nama3ak.runasp.net
DOTNET_API_TOKEN=
DOTNET_PODCAST_PATIENT_ID=

# Email (Optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-password
